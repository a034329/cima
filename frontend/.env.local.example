# Copiar a .env.local. NO commitear .env.local real (gitignored).

# URL del backend Cima en desarrollo.
NEXT_PUBLIC_API_URL=http://localhost:8000

# Modo (debe coincidir con CIMA_MODE del backend). owner = sin login (el backend
# puentea la auth); saas = el middleware exige login. Default: owner.
NEXT_PUBLIC_CIMA_MODE=owner
