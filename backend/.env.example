# Copiar a `.env` y ajustar valores. NO commitear `.env` real (gitignored).
# Variables sensibles van en Railway / Vercel secrets, no en el repo.

# ── Modo de ejecución ────────────────────────────────────────────────
# saas  → producción para clientes (IA capada, disclaimers MiFID)
# owner → instancia personal del fundador (IA sin restricciones, agente externo)
CIMA_MODE=saas

# ── Servidor ─────────────────────────────────────────────────────────
CIMA_HOST=0.0.0.0
CIMA_PORT=8000
CIMA_DEBUG=true
CIMA_ENVIRONMENT=dev

# ── CORS ─────────────────────────────────────────────────────────────
# Lista separada por comas. Json-array también acepta pydantic-settings.
CIMA_CORS_ORIGINS=["http://localhost:3000"]

# ── BD ───────────────────────────────────────────────────────────────
# Dev: SQLite por defecto si no se define (sqlite:///./cima.db).
# Producción (Railway): driver SÍNCRONO (la app usa create_engine sync).
# En Railway, apuntar a la referencia del plugin Postgres:
#   CIMA_DATABASE_URL=${{Postgres.DATABASE_URL}}  (formato postgresql://… → psycopg2)
CIMA_DATABASE_URL=postgresql://cima:cima@localhost:5432/cima_dev

# ── IA: proveedor del clasificador ───────────────────────────────────
# dev: claude_cli (Claude Max) · prod: anthropic (requiere API key) · tests: mock
CIMA_IA_PROVIDER=claude_cli

# ── Anthropic IA (placeholder) ───────────────────────────────────────
CIMA_ANTHROPIC_API_KEY=
CIMA_ANTHROPIC_DEFAULT_MODEL=claude-sonnet-4-6

# ── Datos de mercado: Financial Modeling Prep ────────────────────────
# Sin clave → el feed cae a yfinance (sin consenso de analistas).
CIMA_FMP_API_KEY=

# ── Sentry (placeholder) ─────────────────────────────────────────────
CIMA_SENTRY_DSN=
